# Required for production use
TARGET_SITE_URL=https://speakeragent.ai/
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=
GITHUB_ISSUES_REPO=

# Optional target surfaces
TARGET_API_URL=
FRONTEND_REPO=
BACKEND_REPO=

# Obsidian notes backend.
# Recommended: private GitHub repo that Lester opens as an Obsidian vault.
OBSIDIAN_GITHUB_REPO=
OBSIDIAN_GITHUB_BRANCH=main
OBSIDIAN_VAULT_PATH=SpeakerAgent Ops

# Optional AI council reports. If absent, the service still runs deterministic checks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Scheduler
RUN_SCHEDULER=true
UPTIME_INTERVAL_SECONDS=300
DAILY_REPORT_HOUR_EASTERN=4

# Safety
# true = reports only, no GitHub issue creation. Set false after setup is verified.
DRY_RUN=true
ADMIN_TOKEN=

# Link and browser checks
MAX_LINKS=80
REQUEST_TIMEOUT_SECONDS=20
BROWSER_CHECK_ENABLED=true

